{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "../dist/server",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
